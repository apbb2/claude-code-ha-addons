#!/bin/sh
# Claude Code calls xdg-open to launch a browser for login/OAuth URLs. There is
# no browser inside this container, so deliver the URL to the user instead:
#  - post an HA persistent notification with a clickable markdown link (appears
#    under the bell icon on whatever device the user is using)
#  - save the URL and print a terminal hint as fallback
url="$1"
[ -n "$url" ] || exit 0
printf '%s\n' "$url" > /tmp/claude-last-url

if [ -n "$SUPERVISOR_TOKEN" ]; then
    jq -cn --arg url "$url" '{
        title: "Claude Code — open this link",
        message: ("Claude Code wants to open a page in your browser (usually the login page).\n\n[**Click here to open it**](" + $url + ")\n\nThen return to the terminal to finish."),
        notification_id: "claude_code_open_url"
    }' | curl -sf -X POST \
        -H "Authorization: Bearer $SUPERVISOR_TOKEN" \
        -H "Content-Type: application/json" \
        -d @- http://supervisor/core/api/services/persistent_notification/create >/dev/null 2>&1 || true
fi

{
    printf '\n\033[1;33m* Link sent to Home Assistant notifications (bell icon) - click it there.\033[0m\n'
    printf '\033[2m  Terminal fallback: select the URL shown above and copy it, or run: claude-url\033[0m\n'
} > /dev/tty 2>/dev/null || true
exit 0
